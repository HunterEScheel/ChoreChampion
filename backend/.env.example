# Copy to .env and fill in for local development.

# Database (docker-compose service published on 5433)
DATABASE_URL=postgresql+asyncpg://chorechampion:chorechampion@localhost:5433/chorechampion

# JWT
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-local-env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Join tokens
JOIN_TOKEN_TTL_MINUTES=10

# Environment
ENVIRONMENT=local
